# --- REQUIRED ---
API_ID=1234567
API_HASH=your_api_hash_from_my.telegram.org
BOT_TOKEN=123456:abcdef_your_bot_token_from_botfather
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net
OWNER_ID=123456789

# --- OPTIONAL ---
DB_NAME=auto_rename_bot
ADMINS=                 # space-separated user IDs (besides OWNER_ID)
LOG_CHANNEL=            # e.g. -1001234567890
FORCE_SUB_CHANNEL=      # e.g. "mychannel" or "ch1 ch2" or "-1001234567890"

DEFAULT_TEMPLATE={title} S{season}E{episode} [{quality}] [{audio}]
DEFAULT_CAPTION=<b>{filename}</b>

# Performance
WORKERS=8
MAX_CONCURRENT_USER_TASKS=2
PROGRESS_UPDATE_INTERVAL=6
